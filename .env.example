# Settings for the credit scoring platform.
# All variables use the CS_ prefix and map to Settings in src/credit_scoring/config.py.
# Copy this file to .env and adjust as needed.

CS_ENVIRONMENT=development
CS_LOG_LEVEL=INFO
CS_LOG_JSON=true

# Artifact locations
CS_ARTIFACTS_DIR=artifacts
CS_REGISTRY_DIR=artifacts/registry
CS_REFERENCE_PATH=artifacts/reference.json

# Training
CS_RANDOM_STATE=42
CS_TEST_SIZE=0.2
CS_CV_FOLDS=5

# Business cost of a wrong decision (a missed default costs more than a wrong rejection)
CS_COST_FALSE_NEGATIVE=5.0
CS_COST_FALSE_POSITIVE=1.0

# Drift: a population stability index above this flags a feature
CS_DRIFT_PSI_THRESHOLD=0.2
