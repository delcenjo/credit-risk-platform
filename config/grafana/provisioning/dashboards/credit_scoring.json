{
  "title": "Credit Scoring",
  "uid": "credit-scoring",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Predictions per second by decision",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (decision) (rate(credit_predictions_total[5m]))",
          "legendFormat": "{{decision}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Prediction latency p95 (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(credit_prediction_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "Drift detected",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [{ "expr": "credit_drift_detected" }]
    },
    {
      "id": 4,
      "title": "Feature PSI (last batch)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 18, "x": 6, "y": 8 },
      "targets": [
        { "expr": "credit_feature_psi", "legendFormat": "{{feature}}" }
      ]
    }
  ]
}
